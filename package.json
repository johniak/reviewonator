{
  "name": "reviewonator",
  "version": "0.4.0",
  "description": "A local human-in-the-loop interface for AI-generated GitHub pull request reviews.",
  "private": true,
  "license": "MIT",
  "author": "Jan Romaniak",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johniak/reviewonator.git"
  },
  "homepage": "https://github.com/johniak/reviewonator#readme",
  "bugs": {
    "url": "https://github.com/johniak/reviewonator/issues"
  },
  "keywords": [
    "ai",
    "claude-code",
    "code-review",
    "github",
    "pull-request"
  ],
  "packageManager": "bun@1.3.13",
  "type": "module",
  "scripts": {
    "dev": "bun run build:web && bun src/cli.ts",
    "build": "bun run build:web && bun run build:cli",
    "build:web": "vite build && bun scripts/prepare-web.ts",
    "build:cli": "bun build --compile --minify --target=bun src/cli.ts --outfile dist/reviewonator",
    "typecheck": "tsc --noEmit",
    "test": "bun run build:web && vitest run",
    "test:watch": "vitest",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.19",
    "clsx": "^2.1.1",
    "hono": "^4.12.30",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  }
}
